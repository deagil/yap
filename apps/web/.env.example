# Minimum runtime — use Supabase Postgres connection (Settings → Database → URI)
# Pooler (transaction mode) recommended for serverless
POSTGRES_URL=

# Supabase (required)
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Legacy JWE session (removed in favor of Supabase Auth — keep empty for new deploys)
JWE_SECRET=

# Encryption for workspace secrets and OAuth tokens at rest (32-byte hex = 64 chars)
ENCRYPTION_KEY=

# Slack — used in Supabase Dashboard for Slack OIDC provider (Sign in with Slack)
# Create a Slack app with OpenID Connect; redirect URL from Supabase Auth settings
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Vercel OAuth — workspace integration only ("Connect Vercel for previews"), not sign-in
# Callback URL: {YOUR_ORIGIN}/api/integrations/vercel/callback
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=

# GitHub App (required for repo access, pushes, and PRs)
# Callback URL: {YOUR_ORIGIN}/api/github/app/callback
# Setup URL:    {YOUR_ORIGIN}/api/github/app/callback
# In the GitHub App settings:
#   1. Enable "Request user authorization (OAuth) during installation"
#   2. Use the GitHub App Client ID and Client Secret below
#   3. Make the app public if you want org installs to work cleanly
#   4. Store the private key either as PEM contents with escaped newlines
#      or as a base64-encoded PEM
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# Optional integrations
ELEVENLABS_API_KEY=

# Optional Redis / Vercel KV (skills metadata cache; falls back to in-memory when not set)
REDIS_URL=
KV_URL=

# Optional deployment refinements
VERCEL_PROJECT_PRODUCTION_URL=
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=
VERCEL_SANDBOX_BASE_SNAPSHOT_ID=
